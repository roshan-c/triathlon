NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=

# Set these in Convex environment (npx convex env set ...)
# SITE_URL=http://localhost:3000
# BETTER_AUTH_SECRET=
# PROJECT_ADMIN_EXTERNAL_IDS_JSON=["<better-auth-user-external-id>"]
# AGENT_KEYS_JSON=[{"keyId":"agent-main","key":"sk_live_...","keyLabel":"primary-agent","projectId":"<projectId>","externalId":"<externalId>","enabled":true}]

# Triathlon CLI runtime env (local shell or .env)
# TRI_AGENT_URL=https://<deployment>.convex.site/agent/v1
# TRI_AGENT_KEY=sk_live_...
# TRI_PROJECT_ID=<projectId>
